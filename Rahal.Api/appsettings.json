{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=$DATABASE_HOST;Port=$DATABASE_PORT;Database=$DATABASE_NAME;UserName=$DATABASE_USERNAME;Password=$DATABASE_PASSWORD",
    "Redis": "$REDIS_HOST:$REDIS_PORT,abortConnect=false"
  },
  "RedisSettings": {
    "AbortOnConnectFail": false,
    "ConnectRetry": 3,
    "ConnectTimeout": 5000
  },
  "Serilog": {
    "MinimumLevel": "Debug",
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/logs.txt",
          "rollingInterval": "Year", //Create a new log file each year
          "fileSizeLimitBytes": 1048576,
          "rollOnFileSizeLimit": true //Create a new file when file size limit is reached
        }
      }
    ],
    "Enrich": [
      "FromLogContext" //Any property added to the log context should be enriched (meta data)
    ],
    "Properties": {
      "ApplicationName": "ECommerce App"
    }
  },
  "RateLimitSettings": {
    "RequestLimit": 3,
    "WindowInSeconds": 60,
    "EnableIpRateLimit": true,
    "EnableUserRateLimit": true
  },
  "JwtSettings": {
    "Issuer": "Rahal",
    "Audience": "account",
    "AccessTokenExpiryInMin": 60,
    "RefreshTokenExpiryInDay": 7
  },
  "Mail": {
    "Host": "sandbox.smtp.mailtrap.io",
    "Port": 587,
    "Username": "f93216ff8aa721",
    "Password": "614aa36da386d9",
    "FromEmail": "no-reply@rahal.com",
    "FromName": "Rahal",
    "EnableSsl": true
  },
  "OAuth": {
    "Google": {
      "ClientId": "YOUR_CLIENT_ID.apps.googleusercontent.com"
    }
  },
  "ResilienceSettings": {
    "FileStorage": {
      "MaxRetries": 3,
      "InitialDelaySeconds": 3,
      "CircuitBreakerFailureThreshold": 0.5,
      "CircuitBreakerOpenDurationSeconds": 60,
      "TimeoutSeconds": 30
    },
    "Email": {
      "MaxRetries": 3,
      "InitialDelaySeconds": 2,
      "CircuitBreakerFailureThreshold": 0.5,
      "CircuitBreakerOpenDurationSeconds": 30,
      "TimeoutSeconds": 10
    },
    "Search": {
      "MaxRetries": 3,
      "InitialDelaySeconds": 2,
      "CircuitBreakerFailureThreshold": 0.5,
      "CircuitBreakerOpenDurationSeconds": 30,
      "TimeoutSeconds": 10
    }
  },
  "Meilisearch": {
    "Url": "http://$MEILI_HOST:$MEILI_PORT",
    "ApiKey": "$MEILI_API_KEY"
  }

}
